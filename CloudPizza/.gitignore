## Ignore Visual Studio temporary files, build results, and files generated by IDE

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/

# Rider
.idea/

# .NET / ASP.NET
project.lock.json
project.fragment.lock.json
artifacts/

# NuGet
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/

# Database
*.db
*.db-shm
*.db-wal

# Aspire
.aspire/

# User secrets
secrets.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Local settings
**/appsettings.Local.json
