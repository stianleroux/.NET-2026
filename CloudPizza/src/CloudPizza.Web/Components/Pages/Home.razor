@page "/"
@using System.ComponentModel.DataAnnotations
@using CloudBurger.Shared.Contracts
@using CloudBurger.Shared.Domain
@using CloudBurger.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject ApiClient ApiClient
@inject ILogger<Home> Logger

<PageTitle>Order Burger - CloudBurger</PageTitle>

<div class="container">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h1 class="mb-4">🍕 Order Your Burger</h1>

            @if (orderPlaced)
            {
                <div class="alert alert-success">
                    <h4 class="alert-heading">Order Placed Successfully!</h4>
                    <p><strong>Order ID:</strong> @lastOrderId</p>
                    <p><strong>Customer:</strong> @lastCustomerName</p>
                    <p><strong>Burger:</strong> @lastBurgerType</p>
                    <p><strong>Total:</strong> $@lastTotalPrice</p>
                    <button class="btn btn-primary" @onclick="ResetForm">Place Another Order</button>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-body">
                        <EditForm Model="formModel" OnValidSubmit="HandleSubmit" FormName="orderForm">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="text-danger" />

                            <div class="mb-3">
                                <label class="form-label">Your Name</label>
                                <InputText @bind-Value="formModel.CustomerName" class="form-control" placeholder="Enter your name" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Select Burger</label>
                                <InputSelect @bind-Value="formModel.BurgerType" class="form-select">
                                    <option value="">-- Choose a burger --</option>
                                    @foreach (var burger in Enum.GetValues<BurgerType>())
                                    {
                                        <option value="@burger.ToString()">
                                            @burger.GetDisplayName() - @burger.GetDescription() ($@burger.GetPrice())
                                        </option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Quantity</label>
                                <InputNumber @bind-Value="formModel.Quantity" class="form-control" min="1" max="50" />
                            </div>

                            @if (!string.IsNullOrEmpty(formModel.BurgerType) && Enum.TryParse<BurgerType>(formModel.BurgerType, out var selectedBurger))
                            {
                                <div class="alert alert-info">
                                    <strong>Estimated Total:</strong> $@(selectedBurger.GetPrice() * formModel.Quantity)
                                </div>
                            }

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>Placing Order...</span>
                                    }
                                    else
                                    {
                                        <span>Place Order</span>
                                    }
                                </button>
                            </div>

                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="alert alert-danger mt-3">@errorMessage</div>
                            }
                        </EditForm>
                    </div>
                </div>

                <div class="mt-4">
                    <h3>Available Burgers</h3>
                    <div class="row">
                        @foreach (var burger in Enum.GetValues<BurgerType>())
                        {
                            <div class="col-md-6 mb-3">
                                <div class="card h-100">
                                    <div class="card-body">
                                        <h5 class="card-title">@burger.GetDisplayName()</h5>
                                        <p class="card-text">@burger.GetDescription()</p>
                                        <p class="card-text"><strong>$@burger.GetPrice()</strong></p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private CreateOrderFormModel formModel = new();

    private bool isSubmitting;
    private bool orderPlaced;
    private string? errorMessage;
    private string? lastOrderId;
    private string? lastCustomerName;
    private string? lastBurgerType;
    private decimal lastTotalPrice;

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var orderRequest = new CreateOrderRequest
            {
                CustomerName = formModel.CustomerName,
                BurgerType = formModel.BurgerType,
                Quantity = formModel.Quantity
            };

            var response = await ApiClient.CreateOrderAsync(orderRequest);

            if (response != null)
            {
                orderPlaced = true;
                lastOrderId = response.OrderId;
                lastCustomerName = response.CustomerName;
                lastBurgerType = response.BurgerType;
                lastTotalPrice = response.TotalPrice;
            }
            else
            {
                errorMessage = "Failed to place order. Please try again.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error placing order");
            errorMessage = "An error occurred. Please try again.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ResetForm()
    {
        orderPlaced = false;
        formModel = new();
        errorMessage = null;
    }

    private sealed class CreateOrderFormModel
    {
        [Required]
        [MinLength(2)]
        [MaxLength(100)]
        public string CustomerName { get; set; } = string.Empty;

        [Required]
        public string BurgerType { get; set; } = string.Empty;

        [Range(1, 50)]
        public int Quantity { get; set; } = 1;
    }
}
