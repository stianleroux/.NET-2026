@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <nav class="nav flex-column">
            <div class="nav-item px-3">
                <h3 class="text-white mb-3">🍕 CloudBurger</h3>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Order Burger
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/orders">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Live Orders
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/qrcode">
                    <span class="bi bi-qr-code-nav-menu" aria-hidden="true"></span> QR Code
                </NavLink>
            </div>
        </nav>
    </div>

    <main>
        <div class="top-row px-4">
            <span class="badge bg-success">Connected</span>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
